# Python
__pycache__/
*.pyc
*.pyo

# Large RAM dumps / capture artifacts (research only, never source)
guestram.bin
guestram.manifest.json
*.bin
*.dump
*.pcap

# Local secrets / per-user identity (never commit)
*.dat
*.token
.env

# Runtime logs — contain live IPs/PIDs/session data, never source
*.log

# Launcher build artifacts (PyInstaller) — the frozen exe/version.txt ride on the
# GitHub release, not the repo. Only launcher.py / build_launcher.py / README.md are source.
dist/launcher/build/
dist/launcher/dist/
dist/launcher/*.spec
